[Unit]
Description=My own startscript for Raspberry Pi
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/repo/SmartPlugTools/Python3/theOne.py
WorkingDirectory=/home/pi/repo/SmartPlugTools/Python3
StandardOutput=inherit
StandardError=inherit
Restart=always
User=pi

[Install]
WantedBy=multi-user.target
